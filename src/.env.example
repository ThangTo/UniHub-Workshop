# =====================================================
# UniHub Workshop — root env (used by docker-compose)
# Copy to .env and adjust if needed.
# =====================================================

# --- Postgres ---
POSTGRES_USER=unihub
POSTGRES_PASSWORD=unihub
POSTGRES_DB=unihub
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- RabbitMQ ---
RABBITMQ_USER=unihub
RABBITMQ_PASSWORD=unihub
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# --- MinIO ---
MINIO_ROOT_USER=unihub
MINIO_ROOT_PASSWORD=unihub-secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=unihub

# --- Mailhog ---
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# --- Backend ---
BACKEND_PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Connection strings (used by backend + workers, override in production)
DATABASE_URL=postgresql://unihub:unihub@postgres:5432/unihub?schema=public
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://unihub:unihub@rabbitmq:5672
MINIO_ENDPOINT=minio
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_USE_SSL=false
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM="UniHub <no-reply@unihub.local>"

# Auth
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=unihub-workshop
# RSA RS256 keypair (PEM, dùng "\n" literal cho xuống dòng).
# Để trống → JwksService tự sinh keypair ephemeral mỗi lần khởi động (chỉ DEV).
# Tạo cặp khoá thật bằng:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt.key
#   openssl rsa -in jwt.key -pubout -out jwt.pub
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""
BCRYPT_COST=12

# Bootstrap admin (chỉ dùng cho seed)
BOOTSTRAP_ADMIN_EMAIL=admin@unihub.local
BOOTSTRAP_ADMIN_PASSWORD=Admin@123456
BOOTSTRAP_ADMIN_NAME=System Admin

# Rate limit
RATE_LIMIT_GLOBAL_REGISTRATION_RPS=500
RATE_LIMIT_REGQUEUE_TTL_SECONDS=10

# Idempotency
IDEMPOTENCY_REDIS_TTL_SECONDS=86400

# Circuit breaker (payment)
CB_PAYMENT_TIMEOUT_MS=3000
CB_PAYMENT_ERROR_THRESHOLD=50
CB_PAYMENT_RESET_TIMEOUT_MS=30000
CB_PAYMENT_VOLUME_THRESHOLD=10

# Mock services
MOCK_PG_URL=http://mock-pg:4000
MOCK_PG_WEBHOOK_SECRET=mock-pg-secret
MOCK_AI_URL=http://mock-ai:4100

# CSV sync
CSV_DROP_DIR=/app/data/csv-drop
CSV_QUARANTINE_DIR=/app/data/csv-quarantine
CSV_ARCHIVE_DIR=/app/data/csv-archive
CSV_CRON=0 2 * * *

# Frontends
STUDENT_WEB_PORT=5173
ADMIN_WEB_PORT=5174
VITE_API_BASE_URL=http://localhost:3000
