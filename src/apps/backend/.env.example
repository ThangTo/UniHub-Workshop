# UniHub backend local dev env.
# Copy this file to .env when running apps/backend outside Docker.

NODE_ENV=development
LOG_LEVEL=debug
PORT=3000

# Local infra endpoints. These assume `docker compose up -d postgres redis rabbitmq minio mailhog`.
DATABASE_URL=postgresql://unihub:unihub@localhost:5432/unihub?schema=public
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://unihub:unihub@localhost:5672

# Auth
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=unihub-workshop
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
BCRYPT_COST=12

# Bootstrap admin
BOOTSTRAP_ADMIN_EMAIL=admin@unihub.local
BOOTSTRAP_ADMIN_PASSWORD=Admin@123456
BOOTSTRAP_ADMIN_NAME=System Admin

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=unihub
MINIO_ROOT_PASSWORD=unihub-secret
MINIO_BUCKET=unihub
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# Mailhog SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=UniHub <no-reply@unihub.local>

# Mock payment gateway
MOCK_PG_URL=http://localhost:4000
MOCK_PG_WEBHOOK_SECRET=mock-pg-secret
PAYMENT_TIMEOUT_MS=3000
PAYMENT_CB_ERROR_THRESHOLD=50
PAYMENT_CB_RESET_MS=30000
PAYMENT_CB_VOLUME_THRESHOLD=20
PAYMENT_CB_ROLLING_MS=10000

# Idempotency
IDEMPOTENCY_REDIS_TTL_SECONDS=86400

# Gemini AI summary
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# CSV sync
CSV_DROP_DIR=./data/csv-drop
CSV_QUARANTINE_DIR=./data/csv-quarantine
CSV_ARCHIVE_DIR=./data/csv-archive
CSV_CRON=0 2 * * *

# Registration global queue
RATE_LIMIT_GLOBAL_REGISTRATION_RPS=500
RATE_LIMIT_REGQUEUE_TTL_SECONDS=10
RATE_LIMIT_REGQUEUE_MAX_ITEMS=200000
